<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Portal Urbano</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ProjetoUrbano.styles.css" asp-append-version="true" />
</head>
@{
    var hideHeader = ViewData["HideLayoutHeader"] as bool? ?? false;
}
<body class="@(hideHeader ? "layout-fullscreen" : string.Empty)">
    @if (!hideHeader)
    {
        <header class="border-bottom bg-white py-2">
            <div class="container-fluid portal-header">
                <div></div>
                <div class="portal-center-group">
                    <a class="navbar-brand fw-bold portal-brand" asp-area="" asp-controller="Home" asp-action="Index">Portal Urbano</a>
                    <ul class="nav justify-content-center gap-3 mb-0 portal-nav">
                        <li class="nav-item"><a class="nav-link text-dark px-0" asp-area="" asp-controller="Usuario" asp-action="Login">Login</a></li>
                        <li class="nav-item"><a class="nav-link text-dark px-0" asp-area="" asp-controller="Home" asp-action="Perfil">Perfil</a></li>
                        <li class="nav-item"><a class="nav-link text-dark px-0" asp-area="" asp-controller="Usuario" asp-action="Cadastro">Cadastro</a></li>
                        <li class="nav-item"><a class="nav-link text-dark px-0" asp-area="" asp-controller="Usuario" asp-action="Logout">Sair</a></li>
                        @if (Context.Session.GetString("UsuarioNome") is string nome)
                        {
                            <li class="nav-item"><span class="badge rounded-pill text-bg-light border text-dark px-3 py-2">Olá, @nome</span></li>
                        }
                    </ul>
                </div>
                <div></div>
            </div>
        </header>
    }

    <main role="main" class="@(hideHeader ? "layout-main-full" : "container py-4 pb-5")">
        @RenderBody()
    </main>

    @if (!(ViewData["HideLayoutFooter"] as bool? ?? false))
    {
        <footer class="border-top py-3 bg-white text-center text-muted">
            <div class="container">
                &copy; 2026 - Portal Urbano
            </div>
        </footer>
    }
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
