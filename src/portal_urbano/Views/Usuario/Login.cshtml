@{
    ViewData["Title"] = "Login";
    ViewData["HideLayoutFooter"] = true;
    ViewData["HideLayoutHeader"] = true;
}

<div class="login-page">
    <div class="login-hero">
        <a class="login-brand" asp-controller="Home" asp-action="Index">
            <span class="login-brand-icon">🧭</span>
            <span class="login-brand-text">Portal Urbano</span>
        </a>
    </div>
    <div class="login-panel">
        <div class="login-card">
            <h1 class="login-title">Bem-vindo de volta!</h1>

            @if (ViewBag.Erro != null)
            {
                <div class="alert alert-danger">@ViewBag.Erro</div>
            }

            <form method="post" class="login-form">
                <div class="mb-4">
                    <label class="form-label login-label">Email</label>
                    <input name="email" type="email" class="form-control login-input" placeholder="usuario@email.com" required />
                </div>

                <div class="mb-4">
                    <div class="d-flex justify-content-between align-items-center gap-2">
                        <label class="form-label login-label mb-0">Senha</label>
                        <a asp-controller="Usuario" asp-action="EsqueciSenha" class="login-link">Esqueceu sua senha?</a>
                    </div>
                    <input name="senha" type="password" class="form-control login-input" placeholder="adicione sua senha" required />
                </div>

                <div class="d-flex flex-column gap-2">
                    <button type="submit" class="btn login-btn-primary">Entrar</button>
                </div>
            </form>

            <div class="login-footer">
                <span>Não tem conta?</span>
                <a asp-controller="Usuario" asp-action="Cadastro">Crie uma</a>
            </div>
        </div>
    </div>
</div>
