@{
    ViewData["Title"] = "Esqueci senha";
    ViewData["HideLayoutFooter"] = true;
    ViewData["HideLayoutHeader"] = true;
}

<div class="login-page">
    <div class="esqueci-hero">
        <a class="login-brand" asp-controller="Home" asp-action="Index">
            <span class="login-brand-icon">🧭</span>
            <span class="login-brand-text">PortalUrbano</span>
        </a>
    </div>
    <div class="login-panel">
        <div class="login-card">
            <h1 class="login-title">Recuperar senha</h1>

            @if (ViewBag.Erro != null)
            {
                <div class="alert alert-danger">@ViewBag.Erro</div>
            }
            @if (ViewBag.Sucesso != null)
            {
                <div class="alert alert-success">@ViewBag.Sucesso</div>
            }

            <form method="post" class="login-form">
                <div class="mb-4">
                    <label class="form-label login-label">Email</label>
                    <input name="email" type="email" class="form-control login-input" placeholder="usuario@email.com" required />
                </div>

                <div class="d-flex flex-column gap-2">
                    <button type="submit" class="btn login-btn-primary">Enviar link</button>
                </div>
            </form>

            <div class="login-footer">
                <span>Lembrou a senha?</span>
                <a asp-controller="Usuario" asp-action="Login">Voltar ao login</a>
            </div>
        </div>
    </div>
</div>
